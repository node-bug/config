{
  "name": "@nodebug/config",
  "version": "2.1.2",
  "author": {
    "name": "Node Bug",
    "email": "nodebug@outlook.com"
  },
  "bugs": {
    "url": "https://github.com/node-bug/config/issues"
  },
  "dependencies": {
    "rc": "^1.2.8"
  },
  "description": "A simple configuration reader for Node.js projects",
  "homepage": "https://github.com/node-bug/config#readme",
  "keywords": [
    "config",
    "configuration",
    "nodejs",
    "settings",
    "environment"
  ],
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-bug/config.git"
  },
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint .",
    "prepare": "husky && echo 'npx lint-staged' > .husky/pre-commit && chmod +x .husky/pre-commit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript-eslint": "^8.58.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,md,sh,groovy}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "contributors": [
    {
      "name": "Node Bug",
      "email": "nodebug@outlook.com"
    }
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ]
}
